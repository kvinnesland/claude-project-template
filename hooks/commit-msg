#!/bin/sh
#
# commit-msg hook — enforces CR reference in every commit message.
#
# Install:
#   cp hooks/commit-msg .git/hooks/commit-msg
#   chmod +x .git/hooks/commit-msg
#
# Bypass (emergency only, requires justification in commit body):
#   git commit --no-verify -m "INFRA: ..."

commit_msg=$(cat "$1")

# Allow exempt commit types — prefix or suffix form
if echo "$commit_msg" | grep -qiE '^(Merge|Revert|Initial|INFRA:|DOCS:|CHORE:)|\((INFRA|DOCS|CHORE)\)$'; then
  exit 0
fi

# Require CR-NNN reference
if ! echo "$commit_msg" | grep -qE 'CR-[0-9]+'; then
  echo ""
  echo "ERROR: Commit message must reference a Change Request."
  echo ""
  echo "  Option 1 — CR reference (suffix):"
  echo "    Add user login endpoint (CR-003)"
  echo ""
  echo "  Option 2 — exempt types (no CR needed):"
  echo "    INFRA: update .gitignore"
  echo "    DOCS: fix typo in README"
  echo "    CHORE: bump dependencies"
  echo "    or suffix: Add something (INFRA)"
  echo ""
  exit 1
fi

exit 0
